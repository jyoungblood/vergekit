    "better-auth": "^1.6.19",
    "drizzle-orm": "^0.45.2",
    "nodemailer": "^9.0.1",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260619.1",
